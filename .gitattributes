# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Markdown
*.md text

# Source code
*.html text
*.css text
*.js text

# Documents
*.txt text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
